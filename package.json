{
  "name": "finch",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test \"tests/**/*.test.js\"",
    "app:build": "vite build --base ./ && electron-builder --mac",
    "app:open": "open release/mac-arm64/Finch.app"
  },
  "build": {
    "appId": "nl.yasas.finch",
    "productName": "Finch",
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dir",
      "icon": "build/icon.icns",
      "category": "public.app-category.finance",
      "identity": null
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "idb": "^8.0.2",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  }
}
